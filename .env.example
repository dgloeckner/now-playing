# Spotify app configuration. Copy this file to `.env.local` and fill in the values
# from your Spotify Developer Dashboard app (see .scratch/now-playing-mvp/issues/01).
#
# The Client ID is NOT a secret in the PKCE flow (ADR-0003) — it ships in the
# client bundle. It lives in env config only to keep it out of source and easy
# to swap per environment.

# Your Spotify app's Client ID (Dashboard → your app → Settings → Basic Information).
VITE_SPOTIFY_CLIENT_ID=

# The redirect URI registered on the Spotify app. Must match EXACTLY, including the
# /now-playing/ base path.
#   Dev:  http://127.0.0.1:5173/now-playing/   (NOT localhost — Spotify bans it)
#   Prod: https://<your-username>.github.io/now-playing/
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/now-playing/
